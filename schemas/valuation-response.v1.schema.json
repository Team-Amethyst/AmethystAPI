{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/amethyst/amethyst-api/schemas/valuation-response.v1.schema.json",
  "title": "Amethyst Engine valuation response (v1)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "engine_contract_version",
    "inflation_model",
    "inflation_factor",
    "inflation_raw",
    "inflation_bounded_by",
    "total_budget_remaining",
    "pool_value_remaining",
    "players_remaining",
    "valuations",
    "calculated_at"
  ],
  "properties": {
    "engine_contract_version": {
      "type": "string"
    },
    "inflation_model": {
      "type": "string",
      "enum": [
        "global_v1",
        "surplus_slots_v1",
        "replacement_slots_v2"
      ]
    },
    "inflation_factor": {
      "type": "number"
    },
    "inflation_raw": {
      "type": "number"
    },
    "inflation_bounded_by": {
      "type": "string",
      "enum": [
        "none",
        "cap",
        "floor"
      ]
    },
    "total_budget_remaining": {
      "type": "number"
    },
    "pool_value_remaining": {
      "type": "number"
    },
    "players_remaining": {
      "type": "integer",
      "minimum": 0
    },
    "calculated_at": {
      "type": "string"
    },
    "auction_value_note": {
      "type": "string",
      "description": "Explains valuations[].auction_value as the canonical official dollar valuation (equals adjusted_value)."
    },
    "recommended_bid_note": {
      "type": "string",
      "description": "Explains recommended_bid as a draftroom bid anchor (clearing blend toward baseline), not FMV (use auction_value)."
    },
    "edge_note": {
      "type": "string",
      "description": "Clarifies edge = team_adjusted_value - recommended_bid vs auction_value semantics."
    },
    "valuation_context": {
      "type": "object",
      "description": "Eligible catalog pool vs league-wide empty roster slots.",
      "properties": {
        "eligible_pool_size": { "type": "integer", "minimum": 0 },
        "roster_demand_slots": { "type": "integer", "minimum": 0 },
        "pool_to_slot_ratio": { "type": ["number", "null"] }
      }
    },
    "valuation_context_warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Non-fatal thin-pool / custom-universe / keeper-skew warnings."
    },
    "phase_indicator": {
      "type": "string",
      "enum": ["early", "mid", "late"]
    },
    "market_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scoring_category_warnings": {
      "type": "array",
      "description": "Present when scoring_categories included unsupported v1 category names.",
      "items": {
        "type": "string"
      }
    },
    "valuations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/valuedPlayer"
      }
    },
    "user_team_id_used": {
      "type": "string"
    },
    "team_adjusted_value_note": {
      "type": "string",
      "description": "Explains team_adjusted_value as roster-context marginal worth only, not a universal player price."
    }
  },
  "$defs": {
    "valuedPlayer": {
      "type": "object",
      "required": [
        "player_id",
        "name",
        "position",
        "team",
        "adp",
        "tier",
        "baseline_value",
        "auction_value",
        "adjusted_value",
        "indicator",
        "inflation_factor"
      ],
      "properties": {
        "player_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "position": {
          "type": "string"
        },
        "team": {
          "type": "string"
        },
        "adp": {
          "type": "number"
        },
        "tier": {
          "type": "integer"
        },
        "baseline_value": {
          "type": "number"
        },
        "auction_value": {
          "type": "number",
          "description": "Canonical official dollar valuation for evaluation; equals adjusted_value."
        },
        "adjusted_value": {
          "type": "number"
        },
        "recommended_bid": {
          "type": "number",
          "description": "Draftroom bid suggestion (UX); not the canonical valuation."
        },
        "indicator": {
          "type": "string",
          "enum": [
            "Steal",
            "Reach",
            "Fair Value"
          ]
        },
        "inflation_factor": {
          "type": "number"
        },
        "team_adjusted_value": {
          "type": "number",
          "description": "Team-specific marginal value from need, dollars per open slot vs league, slot scarcity, and replacement drop-off."
        },
        "edge": {
          "type": "number",
          "description": "team_adjusted_value minus recommended_bid."
        },
        "valuation_explain": {
          "$ref": "#/$defs/valuationExplainRow"
        }
      },
      "additionalProperties": true
    },
    "valuationExplainRow": {
      "type": "object",
      "description": "Present when explain_valuation_rows was set on the request. Includes replacement/slot context and baseline risk echoes (age, depth, injury multipliers).",
      "properties": {
        "effective_positions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "replacement_key_used": { "type": ["string", "null"] },
        "replacement_value_used": { "type": ["number", "null"] },
        "surplus_basis": { "type": "number" },
        "inflation_factor": { "type": "number" },
        "pool_size": { "type": "integer", "minimum": 0 },
        "roster_demand_slots": { "type": "integer", "minimum": 0 },
        "pool_to_slot_ratio": { "type": ["number", "null"] },
        "scoring_category_warnings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "valuation_context_warnings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "age_years": { "type": "integer" },
        "age_multiplier": { "type": "number" },
        "depth_chart_position_resolved": { "type": "integer" },
        "depth_multiplier": { "type": "number" },
        "age_depth_combined_multiplier": { "type": "number" },
        "injury_severity": { "type": "integer", "minimum": 0, "maximum": 3 },
        "injury_multiplier": { "type": "number" },
        "age_component": { "type": "number" },
        "depth_component": { "type": "number" }
      },
      "additionalProperties": true
    }
  }
}
