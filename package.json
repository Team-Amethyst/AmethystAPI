{
  "name": "amethyst-api",
  "version": "1.0.0",
  "description": "Backend API for Amethyst Draft with API key licensing",
  "main": "dist/index.js",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "test": "vitest run",
    "dev": "nodemon src/index.ts",
    "build": "pnpm run build:portal && tsc",
    "build:portal": "pnpm --filter amethyst-portal build",
    "dev:portal": "pnpm --filter amethyst-portal dev",
    "start": "node dist/index.js",
    "lint": "eslint src test vitest.config.ts --max-warnings 0",
    "test:watch": "vitest",
    "check-types": "tsc --noEmit",
    "sync-players": "ts-node --project tsconfig.scripts.json scripts/sync-players.ts",
    "audit:player-eligibility": "ts-node --project tsconfig.scripts.json scripts/audit-player-eligibility.ts",
    "sync-players:verify": "pnpm sync-players -- --confirm-universe-write && pnpm audit:player-eligibility",
    "replay-eval": "ts-node --project tsconfig.scripts.json scripts/replay-evaluator.ts",
    "replay-2026-v2": "ts-node --project tsconfig.scripts.json scripts/replay-2026-v2-validation.ts",
    "replay-attribution": "ts-node --project tsconfig.scripts.json scripts/replay-attribution.ts",
    "convert-2026-draft": "ts-node --project tsconfig.scripts.json scripts/convert-2026-draft-xlsx.ts",
    "audit:valuation-response": "ts-node --project tsconfig.scripts.json scripts/valuation-response-audit.ts",
    "calibrate-valuations": "ts-node --project tsconfig.scripts.json scripts/calibrate-valuations.ts",
    "valuation-walkthrough": "ts-node --project tsconfig.scripts.json scripts/real-world-valuation-walkthrough.ts",
    "audit:research-edge": "ts-node --project tsconfig.scripts.json scripts/audit-research-edge-vs-max.ts",
    "audit:monte-carlo-valuations": "ts-node --project tsconfig.scripts.json scripts/monte-carlo-draft-valuation-audit.ts",
    "audit:catalog-identity": "ts-node --project tsconfig.scripts.json scripts/audit-catalog-identity.ts",
    "repair:catalog-identities": "ts-node --project tsconfig.scripts.json scripts/repair-catalog-identities.ts",
    "export:catalog-cleanup-review": "ts-node --project tsconfig.scripts.json scripts/export-catalog-cleanup-review.ts",
    "generate:catalog-cleanup-plan": "ts-node --project tsconfig.scripts.json scripts/generate-catalog-cleanup-plan.ts",
    "apply:catalog-cleanup-allowlist": "ts-node --project tsconfig.scripts.json scripts/apply-catalog-cleanup-allowlist.ts",
    "audit:valuation-factor-influence": "ts-node --project tsconfig.scripts.json scripts/valuation-factor-influence-audit.ts",
    "keeper-pre-draft-audit": "ts-node --project tsconfig.scripts.json scripts/keeper-pre-draft-valuation-audit.ts",
    "pre-draft-before-after": "ts-node --project tsconfig.scripts.json scripts/pre-draft-slot-engine-before-after.ts",
    "replay-four-values": "ts-node --project tsconfig.scripts.json scripts/replay-four-values-eval.ts",
    "replay-per-team-pick": "ts-node --project tsconfig.scripts.json scripts/replay-per-team-pick.ts",
    "replay-per-pick-draft": "ts-node --project tsconfig.scripts.json scripts/replay-per-pick-draft.ts",
    "replay-draft-json-analysis": "ts-node --project tsconfig.scripts.json scripts/replay-draft-json-per-pick-analysis.ts",
    "replay-draft-json-analysis:report": "ts-node --project tsconfig.scripts.json scripts/replay-draft-json-per-pick-analysis.ts --out tmp/draft-json-after_pick_130-proxy-analysis.json",
    "replay-draft-json-analysis:mongo-report": "ts-node --project tsconfig.scripts.json scripts/replay-draft-json-per-pick-analysis.ts --mongo --out tmp/draft-json-after_pick_130-mongo-analysis.json",
    "dedupe-fixtures": "ts-node --project tsconfig.scripts.json scripts/dedupe-fixture-auction-picks.ts",
    "check-fixture-catalog": "ts-node --project tsconfig.scripts.json scripts/check-fixture-catalog-ids.ts",
    "market-adp-preview": "ts-node --project tsconfig.scripts.json scripts/market-adp-ingest-preview.ts",
    "market-adp-apply": "ts-node --project tsconfig.scripts.json scripts/apply-market-adp-updates.ts",
    "market-adp-preview:remote-selftest": "ts-node --project tsconfig.scripts.json scripts/nfbc-remote-preview-selftest.ts",
    "debug:market-adp-match": "ts-node --project tsconfig.scripts.json scripts/debug-market-adp-match.ts",
    "catalog-universe:dry-run": "ts-node --project tsconfig.scripts.json scripts/catalog-universe-dry-run.ts",
    "calibrate:roster-universe-valuation": "ts-node --project tsconfig.scripts.json scripts/calibrate-roster-universe-valuation.ts",
    "investigate:roster-universe-of-collapse": "ts-node --project tsconfig.scripts.json scripts/investigate-roster-universe-of-collapse.ts",
    "audit:value-confidence": "ts-node --project tsconfig.scripts.json scripts/audit-value-confidence.ts"
  },
  "keywords": [
    "api",
    "draft"
  ],
  "author": "Team Amethyst",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "ioredis": "^5.10.0",
    "mongoose": "^9.2.4",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.1",
    "nodemon": "^3.1.13",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.2",
    "vitest": "^4.1.4",
    "xlsx": "^0.18.5"
  }
}
