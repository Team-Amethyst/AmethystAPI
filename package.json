{
  "name": "amethyst-api",
  "version": "1.0.0",
  "description": "Backend API for Amethyst Draft with API key licensing",
  "main": "dist/index.js",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "test": "vitest run",
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src test vitest.config.ts --max-warnings 0",
    "test:watch": "vitest",
    "check-types": "tsc --noEmit",
    "sync-players": "ts-node --project tsconfig.scripts.json scripts/sync-players.ts",
    "audit:player-eligibility": "ts-node --project tsconfig.scripts.json scripts/audit-player-eligibility.ts",
    "sync-players:verify": "pnpm sync-players && pnpm audit:player-eligibility",
    "replay-eval": "ts-node --project tsconfig.scripts.json scripts/replay-evaluator.ts",
    "replay-2026-v2": "ts-node --project tsconfig.scripts.json scripts/replay-2026-v2-validation.ts",
    "replay-attribution": "ts-node --project tsconfig.scripts.json scripts/replay-attribution.ts",
    "convert-2026-draft": "ts-node --project tsconfig.scripts.json scripts/convert-2026-draft-xlsx.ts",
    "audit:valuation-response": "ts-node --project tsconfig.scripts.json scripts/valuation-response-audit.ts",
    "replay-four-values": "ts-node --project tsconfig.scripts.json scripts/replay-four-values-eval.ts",
    "replay-per-team-pick": "ts-node --project tsconfig.scripts.json scripts/replay-per-team-pick.ts",
    "replay-per-pick-draft": "ts-node --project tsconfig.scripts.json scripts/replay-per-pick-draft.ts",
    "replay-draft-json-analysis": "ts-node --project tsconfig.scripts.json scripts/replay-draft-json-per-pick-analysis.ts",
    "replay-draft-json-analysis:report": "ts-node --project tsconfig.scripts.json scripts/replay-draft-json-per-pick-analysis.ts --out tmp/draft-json-after_pick_130-proxy-analysis.json",
    "replay-draft-json-analysis:mongo-report": "ts-node --project tsconfig.scripts.json scripts/replay-draft-json-per-pick-analysis.ts --mongo --out tmp/draft-json-after_pick_130-mongo-analysis.json",
    "dedupe-fixtures": "ts-node --project tsconfig.scripts.json scripts/dedupe-fixture-auction-picks.ts",
    "check-fixture-catalog": "ts-node --project tsconfig.scripts.json scripts/check-fixture-catalog-ids.ts"
  },
  "keywords": [
    "api",
    "draft"
  ],
  "author": "Team Amethyst",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "ioredis": "^5.10.0",
    "mongoose": "^9.2.4",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.1",
    "nodemon": "^3.1.13",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.2",
    "vitest": "^4.1.4",
    "xlsx": "^0.18.5"
  }
}
