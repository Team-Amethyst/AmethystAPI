{
  "name": "amethyst-api",
  "version": "1.0.0",
  "description": "Backend API for Amethyst Draft with API key licensing",
  "main": "dist/index.js",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --max-warnings 0",
    "check-types": "tsc --noEmit",
    "sync-players": "ts-node --project tsconfig.scripts.json scripts/sync-players.ts"
  },
  "keywords": [
    "api",
    "draft"
  ],
  "author": "Team Amethyst",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.0",
    "mongoose": "^9.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "eslint": "^9.39.1",
    "nodemon": "^3.1.13",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.2"
  }
}
