# MongoDB Connection
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/amethystdraft?appName=AmethystDraft

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Admin API Key (for generating other API keys)
ADMIN_API_KEY=admin-key-for-generating-other-keys
