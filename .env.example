# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/amethystapi?appName=AmethystAPI

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379
# Production (Upstash — recommended for App Runner, no VPC required):
#   rediss://<user>:<token>@<host>.upstash.io:6380
REDIS_URL=redis://localhost:6379

# ─── Server ───────────────────────────────────────────────────────────────────
# Local dev: 3001  |  App Runner production: 8080
PORT=3001
# Local dev frontend origin. Set to your production domain in App Runner env vars.
CORS_ORIGIN=http://localhost:5173

# ─── Licensing / The Brain ────────────────────────────────────────────────────
# Not read by the app at runtime — API keys are stored in MongoDB (apikeys collection).
# Insert the first key directly in MongoDB Atlas before first deploy.
# See README for the insertOne command.
